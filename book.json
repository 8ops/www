{
	"title": "8ops's' Handbook",
	"description": "8ops's' Handbook",
	"language": "zh-hans",
	"author": "jesse",
	"plugins": [
		"codesnippet",
		"splitter",
		"page-toc-button",
		"image-captions",
		"editlink",
		"back-to-top-button",
		"-lunr",
		"-search",
		"search-plus",
		"favicon@^0.0.2",
		"tbfed-pagefooter@^0.0.1",
		"theme-default",
		"-highlight",
		"prism",
		"prism-themes",
		"sitemap-general",
		"mermaid-gb3"
	],
	"pluginsConfig": {
		"theme-default": {
			"showLevel": true
		},
		"editlink": {
			"base": "https://github.com/8ops/www",
			"label": "编辑本页"
		},
		"image-captions": {
			"caption": "图片 - _CAPTION_"
		},
		"tbfed-pagefooter": {
			"copyright": "Copyright @8ops.top 2018",
			"modify_label": "Updated at ",
			"modify_format": "YYYY-MM-DD HH:mm:ss"
		},
		"favicon": {
			"shortcut": "favicon.ico",
			"bookmark": "favicon.ico"
		},
		"prism": {
			"css": ["prism-themes/themes/prism-ghcolors.css"]
		},
		"sitemap-general": {
			"prefix": "https://handbook.8ops.top"
		}
	}
}
